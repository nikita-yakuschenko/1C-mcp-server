# Qdrant (должен быть запущен: docker compose up -d)
QDRANT_URL=http://localhost:6333
COLLECTION_NAME=1c_upp_docs

# Модель эмбеддингов (для ingestion)
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# MCP-сервер: HTTP — подключайтесь по адресу в строке поиска клиента
MCP_TRANSPORT=http
MCP_HOST=127.0.0.1
MCP_PORT=8064
MCP_PATH=/mcp
